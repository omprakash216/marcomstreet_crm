PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=marcom_street_crm
JWT_SECRET=marcom_crm_secret_key_2024
APP_NAME=MARCOM STREET CRM
# Canonical public URL for the live app. Use the HTTPS domain and subpath if the
# site is mounted under /crm.
BASE_URL=https://vanyasoft.com/crm

# --- Email OTP (Forgot Password) ---
# Option A: Generic SMTP (Gmail / Brevo / custom)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Vanya Group
SMTP_FROM_EMAIL=no-reply@vanyagroup.com
MAIL_FROM="Vanya Group <no-reply@vanyagroup.com>"
PASSWORD_RESET_BRAND_NAME=Vanya Group
ALLOW_EMAIL_PREVIEW=false

# Option B: Gmail shortcut
# GMAIL_USER=your-gmail@gmail.com
# GMAIL_PASS=your-gmail-app-password

# Option C: Brevo shortcut
# USE_BREVO_SMTP=true
# BREVO_SMTP_USER=your-brevo-login
# BREVO_SMTP_PASS=your-brevo-password

OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=30
RESET_TOKEN_EXPIRY_MINUTES=10
PASSWORD_RESET_MAX_OTP_ATTEMPTS=3
DISABLE_EMAIL_SENDING=false

# --- SMS OTP (Forgot Password) ---
# Option A: MSG91 (https://msg91.com -> API -> Auth Key, Sender ID "VG")
MSG91_AUTH_KEY=
MSG91_SENDER_ID=VG
SMS_PROVIDER=msg91

# Option B: 2Factor.in (https://2factor.in)
# TWO_FACTOR_API_KEY=
# SMS_PROVIDER=2factor

OTP_PREFIX=VG
DEFAULT_PHONE_COUNTRY_CODE=91
MSG91_ROUTE=4

# --- WhatsApp Cloud API (Quotation PDF send) ---
# Use the Phone Number ID from Meta, not the visible phone number.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v20.0

# Fallback aliases supported by the app if you already use these names:
# META_AUTH_TOKEN=
# META_WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_ID=
# META_PHONE_NUMBER_ID=
# META_WHATSAPP_PHONE_NUMBER_ID=
# META_GRAPH_VERSION=v20.0

# Setup CLI:
#   npm run configure:sms -- --msg91=YOUR_AUTH_KEY
# Test:
#   npm run test:sms -- 8083866879
# Or: Super Admin -> System Settings -> SMS OTP section
