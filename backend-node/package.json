{
  "name": "marcom-crm-backend",
  "version": "1.0.0",
  "description": "Node.js backend for MARCOM STREET CRM (converted from PHP)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx kill-port 3000 && npx nodemon server.js",
    "db:test": "node scripts/test-db-connection.js",
    "db:doctor": "node scripts/db-doctor.js",
    "db:bootstrap": "node scripts/ensure-demo-schema.js && node scripts/command-center-migration.js && node scripts/run-migration.js",
    "test:sms": "node scripts/test-sms.js",
    "configure:sms": "node scripts/configure-sms.js",
    "seed:panel-logins": "node scripts/seed-panel-logins.js",
    "standardize:numbers": "node scripts/standardize-document-numbers.js",
    "migrate": "node scripts/run-migration.js",
    "migrate:cc": "node scripts/command-center-migration.js",
    "backfill-attendance": "node scripts/backfill-attendance-rules.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.7",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "pdfkit": "^0.14.0",
    "validator": "^13.12.0"
  }
}
