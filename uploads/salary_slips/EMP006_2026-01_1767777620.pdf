<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Salary Slip</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .header { text-align: center; border-bottom: 2px solid #333; padding-bottom: 10px; }
        .company-name { color: #1e40af; font-size: 24px; margin: 0; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th, td { padding: 8px; text-align: left; border: 1px solid #ddd; }
        .total { background-color: #dbeafe; font-weight: bold; }
        .net-salary { background-color: #1e40af; color: white; font-size: 16px; }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="company-name">MARCOM STREET CRM</h1>
        <p>123 Business Street, Mumbai, Maharashtra 400001</p>
        <h2>SALARY SLIP</h2>
    </div>
    
    <table>
        <tr>
            <td><strong>Employee Name:</strong></td>
            <td>Alex Designer</td>
            <td><strong>Employee Code:</strong></td>
            <td>EMP006</td>
        </tr>
        <tr>
            <td><strong>Designation:</strong></td>
            <td>UI/UX Designer</td>
            <td><strong>Department:</strong></td>
            <td></td>
        </tr>
        <tr>
            <td><strong>Pay Period:</strong></td>
            <td colspan="3">01 Jan 1970 - 01 Jan 1970</td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th>EARNINGS</th>
            <th>Amount (₹)</th>
            <th>DEDUCTIONS</th>
            <th>Amount (₹)</th>
        </tr>
        <tr>
            <td>Basic Salary</td>
            <td>23,333.00</td>
            <td>Provident Fund (PF)</td>
            <td>0.00</td>
        </tr>
        <tr>
            <td>HRA</td>
            <td>0.00</td>
            <td>ESI</td>
            <td>0.00</td>
        </tr>
        <tr>
            <td>Conveyance Allowance</td>
            <td>0.00</td>
            <td>Income Tax (TDS)</td>
            <td>0.00</td>
        </tr>
        <tr>
            <td>Medical Allowance</td>
            <td>0.00</td>
            <td>Professional Tax</td>
            <td>0.00</td>
        </tr>
        <tr>
            <td>Special Allowance</td>
            <td>0.00</td>
            <td>Other Deductions</td>
            <td>0.00</td>
        </tr>
        <tr>
            <td>Other Allowances</td>
            <td>0.00</td>
            <td></td>
            <td></td>
        </tr>
        <tr class="total">
            <td>GROSS EARNINGS</td>
            <td>₹ 23,333.00</td>
            <td>TOTAL DEDUCTIONS</td>
            <td>₹ 0.00</td>
        </tr>
        <tr class="net-salary">
            <td colspan="3">NET SALARY</td>
            <td>₹ 23,333.00</td>
        </tr>
    </table>
    
    <p><em>In Words: Twenty Three Thousand Three Hundred and Thirty Three Rupees Only</em></p>
    <p style="text-align: center; font-size: 10px; color: #666;">This is a computer-generated salary slip.</p>
</body>
</html>